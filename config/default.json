{
  "trading": {
      "market": "BTC-PERP",
      "positionSize": 0.001,
      "leverage": 20,
      "leverageMode": "isolated",
      "maxPositions": 3,
      "timeframe": "15m",
      "profitTarget": 1.5,
      "testMode": true,
      "grid": {
          "levels": 8,
          "spacingPct": 0.8,
          "baseAmount": 50,
          "maxGridCapital": 2000,
          "rangeBoundPct": 5.0,
          "updateIntervalMs": 15000
      }
  },
  "backtest": {
      "grid": {
          "initialCapital": 10000,
          "feeRate": 0.00045,
          "startDate": "2025-01-01",
          "endDate": "2025-06-01",
          "timeframe": "15m"
      }
  },
  "indicators": {
      "rsi": {
          "period": 14,
          "overbought": 75,
          "oversold": 25
      },
      "bollinger": {
          "period": 20,
          "stdDev": 2
      },
      "adx": {
          "period": 14,
          "threshold": 25
      }
  },
  "database": {
      "path": "./db/trades.db"
  },
  "logging": {
      "console": {
          "level": "info"
      },
      "file": {
          "level": "debug",
          "path": "./logs/bot.log"
      }
  },
  "rateLimit": {
      "maxRequestsPerSecond": 10,
      "maxOrdersPerMinute": 30
  }
}
