{
  "paperTrading": {
    "enabled": true,
    "initialCapital": 1000,
    "mode": "dry_run",
    "description": "Paper trading using native BBRSI strategy with ML optimization"
  },
  
  "trading": {
    "symbols": ["BTC-PERP", "ETH-PERP"],
    "timeframe": "15m",
    "checkInterval": 60000,
    "maxPositions": 3,
    "maxLeverage": 3,
    "maxPositionSize": 0.1
  },

  "strategy": {
    "name": "BBRSI",
    "type": "native",
    "indicators": {
      "rsi": { "period": 14, "overbought": 70, "oversold": 30 },
      "bollinger": { "period": 20, "stdDev": 2 },
      "adx": { "period": 14, "threshold": 25 }
    }
  },

  "mlOptimization": {
    "enabled": true,
    "description": "ML-enhanced parameter optimization using native optimizer",
    "models": {
      "primary": "xgboost",
      "fallback": "randomforest"
    },
    "features": [
      "rsi",
      "bollinger_bands",
      "adx",
      "macd",
      "ema",
      "atr"
    ],
    "optimization": {
      "datasetSize": 1000,
      "targetMetric": "sharpe_ratio",
      "retrainInterval": 86400
    }
  },

  "riskManagement": {
    "enabled": true,
    "stopLoss": 0.02,
    "takeProfit": 0.03,
    "maxDrawdown": 0.1,
    "dailyLossLimit": 50,
    "maxPositionSize": 0.1
  },

  "logging": {
    "level": "info",
    "files": {
      "main": "paper-trading.log"
    }
  }
}
