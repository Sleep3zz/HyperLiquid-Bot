# HyperLiquidAlgoBot Environment Configuration

# ============================================
# Hyperliquid Credentials (for direct SDK access)
# ============================================
AGENT_PRIVATE_KEY_TEST=your_private_key_here
AGENT_ADDRESS=your_address_here
NETWORK_TYPE=testnet

# ============================================
# Wayfinder SDK Configuration
# ============================================
WAYFINDER_SDK_PATH=/home/clawdbot/wayfinder-paths-sdk
WAYFINDER_WALLET_LABEL=main

# ============================================
# Trading Configuration
# ============================================
DRY_RUN=true
DEBUG=true

# ============================================
# ML Configuration
# ============================================
ML_MODEL_TYPE=xgboost
ML_DATASET_SIZE=1000
ML_TARGET_METRIC=totalProfitLoss
ML_FEATURE_METHOD=shap

# ============================================
# Risk Management
# ============================================
MAX_LEVERAGE=10
RISK_PER_TRADE=0.05
USE_STOP_LOSS=true
STOP_LOSS_PCT=2.0

# ============================================
# Enhanced Strategy Configuration
# ============================================
USE_FUNDING_FILTER=true
FUNDING_LONG_THRESHOLD=0.0001
FUNDING_SHORT_THRESHOLD=0.0001
FUNDING_LOOKBACK_DAYS=7
USE_VOLATILITY_FILTER=false
MAX_VOLATILITY=0.05
